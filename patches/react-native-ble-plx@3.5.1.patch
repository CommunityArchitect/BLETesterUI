+  @Override
+  public void requestPreferredPhyForDevice(String deviceIdentifier,
+                                           int txPhy,
+                                           int rxPhy,
+                                           int phyOptions,
+                                           final String transactionId,
+                                           final OnSuccessCallback<Device> onSuccessCallback,
+                                           final OnErrorCallback onErrorCallback) {
+    final Device device;
+    try {
+      device = getDeviceById(deviceIdentifier);
+    } catch (BleError error) {
+      onErrorCallback.onError(error);
+      return;
+    }
+
+    final RxBleConnection connection = getConnectionOrEmitError(device.getId(), onErrorCallback);
+    if (connection == null) {
+      return;
+    }
+
+    // RxAndroidBle 1.17.2 (the version pinned by react-native-ble-plx@3.5.1)
+    // does not expose a setPreferredPhy method on RxBleConnection at all -
+    // that API, along with the PhyOption enum, was only added in a later
+    // major version. We reach past the abstraction with a custom operation
+    // that calls the real android.bluetooth.BluetoothGatt#setPreferredPhy
+    // (API 26+, phyOptions matching BluetoothGatt.PHY_OPTION_*) directly,
+    // routed through RxAndroidBle's own operation queue so it doesn't race
+    // with other in-flight GATT operations on the same connection (Android
+    // BLE only allows one outstanding GATT operation at a time). We listen
+    // for the real onPhyUpdate native callback (also added in API 26) to
+    // know when the request actually completed.
+    final SafeExecutor<Device> safeExecutor = new SafeExecutor<>(onSuccessCallback, onErrorCallback);
+
+    final RxBleCustomOperation<Void> setPreferredPhyOp = (bluetoothGatt, rxBleGattCallback, scheduler) ->
+      Observable.create(emitter -> {
+        rxBleGattCallback.setNativeCallback(new BluetoothGattCallback() {
+          @Override
+          public void onPhyUpdate(BluetoothGatt gatt, int updatedTxPhy, int updatedRxPhy, int status) {
+            if (status == BluetoothGatt.GATT_SUCCESS) {
+              emitter.onNext((Void) null);
+              emitter.onComplete();
+            } else {
+              emitter.onError(new BleGattException(bluetoothGatt, status, BleGattOperationType.CONNECTION_PRIORITY_CHANGE));
+            }
+          }
+        });
+        bluetoothGatt.setPreferredPhy(txPhy, rxPhy, phyOptions);
+      });
+
+    final Disposable subscription = connection
+      .queue(setPreferredPhyOp)
+      .doOnDispose(() -> {
+        safeExecutor.error(BleErrorUtils.cancelled());
+        pendingTransactions.removeSubscription(transactionId);
+      }).subscribe((ignored) -> {
+        safeExecutor.success(device);
+        pendingTransactions.removeSubscription(transactionId);
+      }, throwable -> {
+        safeExecutor.error(errorConverter.toError(throwable));
+        pendingTransactions.removeSubscription(transactionId);
+      });
+
+    pendingTransactions.replaceSubscription(transactionId, subscription);
+  }
