+  /**
+   * Requests a preferred PHY (Android only). Falls through as a no-op resolving to the
+   * connected device on platforms/OS versions that don't support PHY negotiation.
+   *
+   * @param {DeviceId} deviceIdentifier Device identifier.
+   * @param {number} txPhy Preferred transmitter PHY. One of Phy.LE_1M / Phy.LE_2M / Phy.LE_CODED.
+   * @param {number} rxPhy Preferred receiver PHY. One of Phy.LE_1M / Phy.LE_2M / Phy.LE_CODED.
+   * @param {number} phyOptions Coding preference when using LE_CODED. One of PhyOption.NoPreferred / S2 / S8.
+   * @param {?TransactionId} transactionId Transaction handle used to cancel operation.
+   * @returns {Promise<Device>} Connected device.
+   */
+  async requestPreferredPhyForDevice(
+    deviceIdentifier: DeviceId,
+    txPhy: number,
+    rxPhy: number,
+    phyOptions: number = 0,
+    transactionId: ?TransactionId
+  ): Promise<Device> {
+    if (!transactionId) {
+      transactionId = this._nextUniqueID()
+    }
+    const nativeDevice = await this._callPromise(
+      BleModule.requestPreferredPhyForDevice(deviceIdentifier, txPhy, rxPhy, phyOptions, transactionId)
+    )
+    return new Device(nativeDevice, this)
+  }
